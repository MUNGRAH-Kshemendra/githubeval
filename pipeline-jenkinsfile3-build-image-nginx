pipeline {
    agent any
    stages {
        stage('Clean & Checkout') {
            steps {
                cleanWs()
                git branch: 'main',
                    credentialsId: 'Tocken-Git',
                    url: 'https://github.com/MUNGRAH-Kshemendra/githubeval.git'
            }
        }
        stage('Build-image-nginx') {
            steps {
                sh 'sudo usermod -aG docker jenkins'
                sh 'sudo chmod 666 /var/run/docker.sock'
                sh 'docker build -t my-nginx -f "githubeval/DockerFile" "/githubeval"'
            }
        }
    }
}
