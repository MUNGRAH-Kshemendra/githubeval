pipeline {
    agent any

    stages {

        stage('Clean mon projet') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout SCM') {
            steps {
                git branch: 'main', credentialsId: 'Tocken-Git', url: 'https://github.com/MUNGRAH-Kshemendra/githubeval.git'
            }
        }

        stage('installer docker') {
            steps {
                sh 'sudo apt update'
                sh 'sudo apt upgrade -y'
                sh 'sudo apt install apt-transport-https ca-certificates curl software-properties-common -y'
                sh 'sudo apt install docker.io -y'
                sh 'sudo apt update'
                sh 'sudo usermod -aG docker jenkins'
                sh 'sudo systemctl start docker'
            }
        }
    }
}
