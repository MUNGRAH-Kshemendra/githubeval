pipeline {
    agent any
    stages {
        stage('Clean le projet') {
            steps {
                cleanWs()
            }
        }
        stage('CkeckOut SCM') {
            steps {
                git branch: 'main', credentialsId: 'Tocken-Git', url: 'https://github.com/MUNGRAH-Kshemendra/githubeval.git'
            }
        }


        stage('installer docker') {
            steps {
                sh 'sudo apt autoremove docker.io docker-compose -y'
                sh 'sudo apt update'
                sh 'sudo apt upgrade -y'
                sh 'sudo apt install apt-transport-https ca-certificates curl software-properties-common -y'
                sh 'sudo apt install docker.io -y'
                sh 'sudo apt update'
                sh 'sudo usermod -aG docker jenkins'
                sh 'sudo systemctl start docker'
            }
        }



        stage('Build-image-nginx') {
            steps {
                sh 'sudo usermod -aG docker jenkins'
                sh 'sudo chmod 666 /var/run/docker.sock'
                sh 'docker build -t my-nginx -f "$WORKSPACE/DockerFile" "$WORKSPACE"'
            }
        }

        stage('Create-conteneur') {
            steps {
                sh 'docker stop myapp && docker rm myapp'
                sh 'docker run -d --name myapp --ip 192.168.115.16 -p 8080:80 my-nginx:latest'
                sh 'docker start myapp'
                sh 'docker exec myapp /etc/init.d/nginx start'
            }
        }
    }
}
